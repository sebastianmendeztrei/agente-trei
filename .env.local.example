# --- OpenAI ---
# Key del servidor. NUNCA debe llevar el prefijo NEXT_PUBLIC_.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Modelo a usar. Verifica el nombre exacto disponible en tu cuenta
# en https://platform.openai.com antes de fijarlo aquí.
OPENAI_MODEL=gpt-5-nano

# --- Supabase ---
# URL pública del proyecto (esta sí puede ir al cliente si se necesita).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Anon key (pública, permisos limitados por RLS). Solo si el frontend
# necesita hablarle directo a Supabase (no es el caso en este diseño).
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# Service role key: acceso total, SOLO se usa en el servidor
# (API Routes). Jamás debe tener prefijo NEXT_PUBLIC_ ni llegar al cliente.
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Límites de seguridad de queries (usados por el backend) ---
MAX_ROWS_PER_QUERY=200
